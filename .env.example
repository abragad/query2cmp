# LLM backend: openai (default) or apple (on-device, macOS 26+)
LLM_BACKEND=openai

# OpenAI backend (required when LLM_BACKEND=openai)
# Works with: OpenAI, Azure OpenAI, local proxies (Ollama, LiteLLM, etc.)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# MCP server connection
# For remote HTTP server, use full URL (e.g. https://example.com/mcp)
# For local stdio server, use path to script (e.g. ./server.py or /path/to/server.js)
MCP_SERVER_URL=http://localhost:8000/mcp

# MCP language: translate query to this language before tool selection (e.g. en, English)
# Leave empty to skip translation
MCP_LANGUAGE=en

# Optional: verbose mode (explain each step) - set to true for education/debugging
QUERY2MCP_VERBOSE=true
